@inherits LayoutComponentBase
@inject NavigationManager Nav

<MudThemeProvider @ref="_mudThemeProvider" @bind-IsDarkMode="_isDarkMode" />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Surface" Fixed="true">
        <MudText Typo="Typo.h6" Class="ml-3 font-weight-bold cursor-pointer"
                 @onclick='() => Nav.NavigateTo("/")'>
            AW.dev
        </MudText>
        <MudSpacer />
        <MudButton Href="/" Color="Color.Inherit" Variant="Variant.Text">Accueil</MudButton>
        <MudButton Href="/about" Color="Color.Inherit" Variant="Variant.Text">À propos</MudButton>
        <MudButton Href="/projects" Color="Color.Inherit" Variant="Variant.Text">Projets</MudButton>
        <MudButton Href="/contact" Color="Color.Inherit" Variant="Variant.Text">Contact</MudButton>
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit"
                       OnClick="ToggleTheme"
                       Class="ml-2" />
    </MudAppBar>

    <MudMainContent Class="pt-16">
        @Body
    </MudMainContent>

    <MudAppBar Bottom="true" Elevation="1" Color="Color.Surface" Fixed="true" Dense="true">
        <MudSpacer />
        <MudText Typo="Typo.caption" Class="mud-text-secondary">
            Construit avec Blazor .NET 8 + Squad AI Agents — @DateTime.Now.Year
        </MudText>
        <MudSpacer />
    </MudAppBar>
</MudLayout>

@code {
    private MudThemeProvider _mudThemeProvider = null!;
    private bool _isDarkMode = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isDarkMode = await _mudThemeProvider.GetSystemPreference();
            StateHasChanged();
        }
    }

    private void ToggleTheme() => _isDarkMode = !_isDarkMode;
}

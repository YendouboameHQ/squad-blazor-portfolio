@page "/projects"
@inject PortfolioDataService DataService
<PageTitle>Projets — Aimé WOAGOU</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8 mb-8">
    <MudText Typo="Typo.h3" Class="font-weight-bold mb-2">Projets</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-6">
        Une sélection de mes réalisations. Filtrez par technologie.
    </MudText>

    <!-- Filtre par tag -->
    <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap" Class="mb-6">
        <MudChip T="string" OnClick="@(() => SelectTag(null))"
                 Color="@(_selectedTag == null ? Color.Primary : Color.Default)"
                 Variant="@(_selectedTag == null ? Variant.Filled : Variant.Outlined)">
            Tous
        </MudChip>
        @foreach (var tag in _allTags)
        {
            <MudChip T="string" OnClick="@(() => SelectTag(tag))"
                     Color="@(_selectedTag == tag ? Color.Primary : Color.Default)"
                     Variant="@(_selectedTag == tag ? Variant.Filled : Variant.Outlined)">
                @tag
            </MudChip>
        }
    </MudStack>

    <!-- Grille de projets -->
    <MudGrid Spacing="3">
        @foreach (var project in FilteredProjects)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="2" Style="height: 100%;">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.h6">@project.Title</MudText>
                                @if (project.IsFeatured)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning">Featured</MudChip>
                                }
                            </MudStack>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                            @project.Description
                        </MudText>
                        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                            @foreach (var tag in project.Tags)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@tag</MudChip>
                            }
                        </MudStack>
                    </MudCardContent>
                    <MudCardActions>
                        @if (project.GitHubUrl != null)
                        {
                            <MudButton Href="@project.GitHubUrl" Target="_blank"
                                       StartIcon="@Icons.Custom.Brands.GitHub"
                                       Size="Size.Small">
                                Code
                            </MudButton>
                        }
                        @if (project.LiveUrl != null)
                        {
                            <MudButton Href="@project.LiveUrl" Target="_blank"
                                       StartIcon="@Icons.Material.Filled.OpenInNew"
                                       Size="Size.Small" Color="Color.Primary">
                                Demo
                            </MudButton>
                        }
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
</MudContainer>

@code {
    private string? _selectedTag;
    private IReadOnlyList<ProjectModel> _projects = [];
    private IReadOnlyList<string> _allTags = [];

    protected override void OnInitialized()
    {
        _projects = DataService.GetProjects();
        _allTags = DataService.GetAllTags();
    }

    private IEnumerable<ProjectModel> FilteredProjects =>
        _selectedTag == null
            ? _projects
            : _projects.Where(p => p.Tags.Contains(_selectedTag));

    private void SelectTag(string? tag) => _selectedTag = tag;
}

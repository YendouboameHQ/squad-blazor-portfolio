@page "/projects"
@inject PortfolioDataService DataService
@inject GitHubService GitHubService
<PageTitle>Projets — Aimé WOAGOU</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8 mb-8">
    <MudText Typo="Typo.h3" Class="font-weight-bold mb-2">Projets</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-6">
        Une sélection de mes réalisations. Filtrez par technologie.
    </MudText>

    <!-- Filtre par tag -->
    <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap" Class="mb-6">
        <MudChip T="string" OnClick="@(() => SelectTag(null))"
                 Color="@(_selectedTag == null ? Color.Primary : Color.Default)"
                 Variant="@(_selectedTag == null ? Variant.Filled : Variant.Outlined)">
            Tous
        </MudChip>
        @foreach (var tag in _allTags)
        {
            <MudChip T="string" OnClick="@(() => SelectTag(tag))"
                     Color="@(_selectedTag == tag ? Color.Primary : Color.Default)"
                     Variant="@(_selectedTag == tag ? Variant.Filled : Variant.Outlined)">
                @tag
            </MudChip>
        }
    </MudStack>

    <!-- Grille de projets -->
    <MudGrid Spacing="3">
        @{ int _idx = 0; }
        @foreach (var project in FilteredProjects)
        {
            var delay = $"delay-{Math.Min(++_idx, 6)}";
            <MudItem xs="12" sm="6" md="4" Class="@($"animate-fade-in-up {delay}")">
                <MudCard Elevation="2" Class="card-hover" Style="height: 100%;">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.h6">@project.Title</MudText>
                                @if (project.IsFeatured)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning">Featured</MudChip>
                                }
                            </MudStack>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                            @project.Description
                        </MudText>
                        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                            @foreach (var tag in project.Tags)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@tag</MudChip>
                            }
                        </MudStack>
                    </MudCardContent>
                    <MudCardActions>
                        @if (project.GitHubUrl != null)
                        {
                            <MudButton Href="@project.GitHubUrl" Target="_blank"
                                       StartIcon="@Icons.Custom.Brands.GitHub"
                                       Size="Size.Small">
                                Code
                            </MudButton>
                        }
                        @if (project.LiveUrl != null)
                        {
                            <MudButton Href="@project.LiveUrl" Target="_blank"
                                       StartIcon="@Icons.Material.Filled.OpenInNew"
                                       Size="Size.Small" Color="Color.Primary">
                                Demo
                            </MudButton>
                        }
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
    <!-- Section GitHub live -->
    <MudDivider Class="my-8" />
    <MudText Typo="Typo.h5" Class="font-weight-bold mb-1 animate-fade-in-up">
        <MudIcon Icon="@Icons.Custom.Brands.GitHub" Class="mr-2" />Activité GitHub live
    </MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
        Repos publics mis à jour en temps réel via l'API GitHub.
    </MudText>

    @if (_loadingRepos)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
    }
    else if (_githubRepos.Count == 0)
    {
        <MudAlert Severity="Severity.Info">Impossible de charger les repos GitHub.</MudAlert>
    }
    else
    {
        <MudGrid Spacing="2">
            @{ int _gi = 0; }
            @foreach (var repo in _githubRepos.Take(6))
            {
                var gDelay = $"delay-{Math.Min(++_gi, 6)}";
                <MudItem xs="12" sm="6" md="4" Class="@($"animate-fade-in-up {gDelay}")">
                    <MudCard Elevation="1" Class="card-hover" Style="height: 100%;">
                        <MudCardContent>
                            <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-1">@repo.Name</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3" Style="min-height: 40px;">
                                @(repo.Description ?? "—")
                            </MudText>
                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                @if (repo.Language != null)
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@repo.Language</MudChip>
                                }
                                <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" />
                                <MudText Typo="Typo.caption">@repo.Stargazers_count</MudText>
                            </MudStack>
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Href="@repo.Html_url" Target="_blank"
                                       StartIcon="@Icons.Custom.Brands.GitHub"
                                       Size="Size.Small">
                                Voir
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    private string? _selectedTag;
    private IReadOnlyList<ProjectModel> _projects = [];
    private IReadOnlyList<string> _allTags = [];
    private IReadOnlyList<GitHubRepo> _githubRepos = [];
    private bool _loadingRepos = true;

    protected override void OnInitialized()
    {
        _projects = DataService.GetProjects();
        _allTags = DataService.GetAllTags();
    }

    protected override async Task OnInitializedAsync()
    {
        _githubRepos = await GitHubService.GetReposAsync();
        _loadingRepos = false;
    }

    private IEnumerable<ProjectModel> FilteredProjects =>
        _selectedTag == null
            ? _projects
            : _projects.Where(p => p.Tags.Contains(_selectedTag));

    private void SelectTag(string? tag) => _selectedTag = tag;
}
